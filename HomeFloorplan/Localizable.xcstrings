    "drawing.help.openings.message" : {
      "comment" : "Help message for the \"Doors and windows\" section in the drawing editor help sheet.",
      "extractionState" : "extracted_with_value",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Choose Door or Window, then tap a wall. Select the opening to move it, resize it, or flip the door swing."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Scegli Porta o Finestra, poi tocca un muro. Seleziona l'apertura per spostarla, ridimensionarla o invertire il verso della porta."
          }
        }
      }
    },
