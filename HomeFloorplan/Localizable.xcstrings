    "drawing.help.export.message" : {
      "comment" : "Message for the \"Export\" section of the drawing editor help sheet.",
      "extractionState" : "extracted_with_value",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Legacy keeps the old screen-based export. Adaptive uses the newer stable landscape export for testing."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Legacy mantiene il vecchio export basato sullo schermo. Adattivo usa il nuovo export orizzontale stabile, in fase di test."
          }
        }
      }
    },
