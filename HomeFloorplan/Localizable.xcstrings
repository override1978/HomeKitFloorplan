      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "\"Night starts at\" sets when the Evening phase transitions to Night for this room. Enable \"Silence Window\" to define a time range during which no scene is activated — useful to avoid lights turning on before you wake up."
          }
        }
      }
    },
    "smartlighting.edit.general.footer.window" : {
      "comment" : "Text displayed in a footer below a lighting profile's general section, indicating that the lighting engine is silent during a specified time window. The first argument is the sleep hour. The second argument is the wake hour.",
