    "drawing.help.snap.message" : {
      "comment" : "Description of the snap feature in the help sheet.",
      "extractionState" : "extracted_with_value",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Use the magnet to switch between grid-only snapping and smart snapping to nearby wall endpoints. Wall drawing also aligns to the nearest 45-degree angle."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Usa il magnete per passare dall'aggancio alla sola griglia all'aggancio smart agli estremi dei muri vicini. Il disegno dei muri si allinea anche all'angolo di 45° più vicino."
          }
        }
      }
    },
